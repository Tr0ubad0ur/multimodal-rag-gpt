# Linux/CUDA profile for a short-lived server run.
# Copy to .env.gpu and fill in real secrets on the target machine.

APP_MODE=web
BACKEND_CONFIG_PATH=/app/backend/backend_config.gpu.yaml

SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me
QDRANT_URL=http://qdrant:6333

ADMIN_API_KEY=replace_me
ADMIN_RATE_LIMIT_PER_MINUTE=60
INGEST_POLLER_ENABLED=false
INGEST_WORKER_MAX_CONCURRENCY=2

LLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
LLM_AVAILABLE_MODELS=Qwen/Qwen2-VL-2B-Instruct,Qwen/Qwen2.5-VL-7B-Instruct,llava-hf/llava-onevision-qwen2-7b-ov-hf,openai/gpt-oss-20b
LLM_MAX_NEW_TOKENS=256
LLM_TORCH_DTYPE=float16
LLM_DEVICE_MAP=auto
LLM_ATTN_IMPLEMENTATION=sdpa
LLM_LOW_CPU_MEM_USAGE=true
LLM_LOAD_IN_4BIT=false
RAG_MAX_CONTEXT_DOCS=4
RAG_MAX_CONTEXT_CHARS=2400
LLM_FAST_MODE=false

INGEST_ENABLE_OCR=true
INGEST_OCR_TIMEOUT_SECONDS=10
EMBEDDING_VIDEO_SAMPLE_FPS=0.5

HF_HOME=/models/hf-cache
TRANSFORMERS_CACHE=/models/hf-cache
HUGGINGFACE_HUB_CACHE=/models/hf-cache
TORCH_HOME=/models/torch-cache

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
